# ============================================================
# Copie este arquivo para .env e ajuste os valores
# cp .env.example .env
# ============================================================

# Banco de dados
POSTGRES_DB=bolinhodb
POSTGRES_USER=bolinho_user
POSTGRES_PASSWORD=bolinho_pass

# JWT — TROQUE em produção!
JWT_SECRET=bolinho-docker-local-secret-troque-em-prod
JWT_EXPIRATION_HOURS=24

# WhatsApp Z-API — espelha application.properties / application-prod.properties
# false = só logs da API (simulado). true + IDs abaixo = envio real.
ZAPI_ENABLED=false
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
# Número do dono (alertas internos: estoque, contas, resumo)
ZAPI_OWNER_PHONE=
